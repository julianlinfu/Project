.home-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 64rpx 48rpx;
}

.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--color-text-muted);
  display: block;
}

.hint {
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 16rpx;
  display: block;
}

.btn-primary {
  width: 100%;
  max-width: 600rpx;
  padding: 28rpx;
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-refresh {
  width: 100%;
  max-width: 600rpx;
  padding: 28rpx;
  background: var(--color-surface);
  color: var(--color-accent);
  border: 1rpx solid var(--color-accent);
  border-radius: 16rpx;
  font-size: 30rpx;
}

.admin-entry {
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #9ca3af;
  text-decoration: underline;
}
