.home-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 64rpx 48rpx;
}

.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 104rpx;
  display: block;
  margin-bottom: 24rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.role-list {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.role-card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 36rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.role-card:active {
  opacity: 0.9;
}

.role-emoji {
  font-size: 56rpx;
  flex-shrink: 0;
}

.role-text {
  flex: 1;
}

.role-name {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.role-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
}
