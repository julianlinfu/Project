<view class="home-wrap" wx:if="{{!loading}}">

  <!-- 未注册 -->
  <block wx:if="{{status === 'unregistered'}}">
    <view class="logo-area">
      <text class="logo-icon">🏭</text>
      <text class="title">流水线管理</text>
      <text class="subtitle">首次使用，请先注册</text>
    </view>
    <button class="btn-primary" bindtap="goRegister">注册加入</button>
    <view class="admin-entry" bindtap="goAdmin">管理员入口</view>
  </block>

  <!-- 待审批 -->
  <block wx:elif="{{status === 'pending'}}">
    <view class="logo-area">
      <text class="logo-icon">⏳</text>
      <text class="title">{{realName}}</text>
      <text class="subtitle">你的账户正在等待管理员审批</text>
      <text class="hint">请联系管理员通过你的申请</text>
    </view>
    <button class="btn-refresh" bindtap="checkUser">刷新状态</button>
    <view class="admin-entry" bindtap="goAdmin">管理员入口</view>
  </block>

  <!-- 已停用 -->
  <block wx:elif="{{status === 'disabled'}}">
    <view class="logo-area">
      <text class="logo-icon">🚫</text>
      <text class="title">账户已停用</text>
      <text class="subtitle">请联系管理员了解详情</text>
    </view>
    <view class="admin-entry" bindtap="goAdmin">管理员入口</view>
  </block>

</view>
