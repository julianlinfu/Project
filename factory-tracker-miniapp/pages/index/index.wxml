<view class="home-wrap">
  <view class="logo-area">
    <text class="logo-icon">⚙</text>
    <text class="title">流水线管理</text>
    <text class="subtitle">选择你的身份进入系统</text>
  </view>

  <view class="role-list">
    <view class="role-card" bindtap="goWorker">
      <text class="role-emoji">🔧</text>
      <view class="role-text">
        <text class="role-name">工人</text>
        <text class="role-desc">记录工序进度</text>
      </view>
      <text class="arrow">→</text>
    </view>

    <view class="role-card" bindtap="goAdmin">
      <text class="role-emoji">📊</text>
      <view class="role-text">
        <text class="role-name">管理员</text>
        <text class="role-desc">查看实时进度</text>
      </view>
      <text class="arrow">→</text>
    </view>
  </view>
</view>
