.page-wrap {
  max-width: 960rpx;
  margin: 0 auto;
  padding: 60rpx 32rpx;
}

.reg-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.reg-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.reg-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.reg-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.form-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 30rpx;
  background: var(--color-surface);
  color: var(--color-text);
}

.input-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 12rpx;
  display: block;
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary:active {
  opacity: 0.85;
}
