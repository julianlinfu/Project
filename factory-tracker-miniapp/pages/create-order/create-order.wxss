.page-wrap {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 30rpx;
  background: #ffffff;
  color: #111827;
  box-sizing: border-box;
}

.picker-val {
  color: #9ca3af;
  font-size: 30rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: #ffffff;
  color: #111827;
  box-sizing: border-box;
}

.alert-area {
  border-color: #fca5a5;
  background: #fff5f5;
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: #1a1a1a;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

.btn-primary:active {
  opacity: 0.85;
}
